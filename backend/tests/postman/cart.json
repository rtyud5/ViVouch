{
  "info": {
    "_postman_id": "c1f735f1-39c4-4e31-8db2-df66b72a6b25",
    "name": "ViVouch Cart API",
    "description": "Postman Collection nháp cho Cart API của dự án ViVouch. Cấu hình xác thực Bearer Token thừa hưởng từ môi trường thông qua biến {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart"
              ]
            },
            "description": "Lấy thông tin chi tiết giỏ hàng hiện tại của user cùng cartTotal."
          },
          "response": []
        },
        {
          "name": "Add Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"voucherId\": \"d2e3f4a5-6789-0abc-def1-234567890abc\",\n  \"qty\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/cart/items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart",
                "items"
              ]
            },
            "description": "Thêm một voucher vào giỏ hàng. Cộng dồn số lượng nếu trùng voucherId."
          },
          "response": []
        },
        {
          "name": "Update Quantity",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qty\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/cart/items/cart-item-uuid-001",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart",
                "items",
                "cart-item-uuid-001"
              ]
            },
            "description": "Cập nhật số lượng của một item xác định trong giỏ hàng."
          },
          "response": []
        },
        {
          "name": "Remove Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/items/cart-item-uuid-001",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart",
                "items",
                "cart-item-uuid-001"
              ]
            },
            "description": "Xóa hoàn toàn một item ra khỏi giỏ hàng."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
