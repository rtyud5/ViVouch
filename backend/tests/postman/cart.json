{
  "info": {
    "_postman_id": "c1f735f1-39c4-4e31-8db2-df66b72a6b25",
    "name": "ViVouch Cart API",
    "description": "Postman Collection cho Cart API của dự án ViVouch. Cấu hình xác thực Bearer Token thừa hưởng từ môi trường thông qua biến {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has success structure\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.have.property('items');",
                  "    pm.expect(jsonData.data).to.have.property('cartTotal');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart"
              ]
            },
            "description": "Lấy thông tin chi tiết giỏ hàng hiện tại của user cùng cartTotal."
          },
          "response": []
        },
        {
          "name": "Add Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Add item success\", function () {",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "if (jsonData.success && jsonData.data && jsonData.data.items) {",
                  "    pm.test(\"Verify item exists and save cartItemId\", function () {",
                  "        var addedItem = jsonData.data.items.find(item => item.voucherId === 'b6afab88-4f6b-4001-b5f5-02b70720d6d3');",
                  "        pm.expect(addedItem).to.not.be.undefined;",
                  "        pm.environment.set(\"cart_item_id\", addedItem.id);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"voucherId\": \"b6afab88-4f6b-4001-b5f5-02b70720d6d3\",\n  \"qty\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/cart/items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart",
                "items"
              ]
            },
            "description": "Thêm một voucher vào giỏ hàng. Cộng dồn số lượng nếu trùng voucherId."
          },
          "response": []
        },
        {
          "name": "Update Quantity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Quantity updated successfully\", function () {",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    var item = jsonData.data.items.find(item => item.id === pm.environment.get(\"cart_item_id\"));",
                  "    pm.expect(item.qty).to.eql(5);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qty\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/cart/items/{{cart_item_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart",
                "items",
                "{{cart_item_id}}"
              ]
            },
            "description": "Cập nhật số lượng của một item xác định trong giỏ hàng."
          },
          "response": []
        },
        {
          "name": "Remove Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Item removed successfully\", function () {",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    var item = jsonData.data.items.find(item => item.id === pm.environment.get(\"cart_item_id\"));",
                  "    pm.expect(item).to.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/items/{{cart_item_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart",
                "items",
                "{{cart_item_id}}"
              ]
            },
            "description": "Xóa hoàn toàn một item ra khỏi giỏ hàng."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
