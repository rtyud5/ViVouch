NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voucher_platform?schema=public

JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# OTP and transactional email
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_DELIVERY_MODE=SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_EHLO_HOST=localhost
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_app_password
MAIL_FROM_NAME=ViVouch
MAIL_FROM_ADDRESS=no-reply@example.com
OTP_PEPPER=replace_with_a_long_random_otp_pepper
OTP_EXPIRES_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# payOS VietQR. Leave all three credentials empty to disable real payment.
PAYOS_API_BASE_URL=https://api-merchant.payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:5173/customer/payment-result
PAYOS_CANCEL_URL=http://localhost:5173/customer/payment-result
PAYOS_LINK_EXPIRES_MINUTES=15

# Demo marketplace settings
DEMO_WALLET_INITIAL_BALANCE=1000000
PLATFORM_COMMISSION_RATE=10
ENABLE_VOUCHER_RECONCILIATION_JOB=true
RECONCILIATION_INTERVAL_MS=60000
ENABLE_EMAIL_WORKER=true
EMAIL_WORKER_INTERVAL_MS=60000
