generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  PARTNER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PartnerMemberRole {
  OWNER
  STAFF
}

enum PartnerMemberStatus {
  INVITED
  ACTIVE
  INACTIVE
}

enum OtpPurpose {
  REGISTER
  RESET_PASSWORD
  STAFF_SETUP
}

enum VoucherStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ON_SALE
  PAUSED
  EXPIRED
  REJECTED
  SUSPENDED
}

enum VoucherCodeStatus {
  ISSUED
  USED
  EXPIRED
  CANCELLED
  LOCKED
  REFUND_PENDING
  REFUNDED
}

enum OrderStatus {
  PENDING_PAYMENT
  COMPLETED
  REFUND_PENDING
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  VIVOUCH_WALLET
  PAYOS
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  FAILED
}

enum WalletTransactionType {
  PAYMENT
  REFUND
  ADMIN_ADJUSTMENT
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  MANUAL_REFUND_REQUIRED
  REFUNDED
}

enum SupportTicketType {
  PAYMENT_PROBLEM
  VOUCHER_NOT_ACCEPTED
  REFUND_REQUEST
  CODE_PROBLEM
  OTHER
}

enum SupportTicketStatus {
  OPEN
  PROCESSING
  RESOLVED
  REJECTED
}

enum NotificationType {
  PAYMENT_SUCCESS
  VOUCHER_ISSUED
  REFUND_RESOLVED
  TICKET_RESPONDED
  PARTNER_APPROVED
  PARTNER_REJECTED
  VOUCHER_APPROVED
  VOUCHER_REJECTED
  STAFF_ACCOUNT_CREATED
}

enum EmailDeliveryStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum CmsPageStatus {
  DRAFT
  PUBLISHED
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  phone              String?    @unique
  passwordHash       String
  fullName           String
  role               Role       @default(CUSTOMER)
  status             UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt    DateTime?
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  partner            Partner?
  partnerMemberships PartnerMember[]
  cart               Cart?
  orders              Order[]
  voucherCodes        VoucherCode[]
  reviews             Review[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  emailOtps           EmailOtp[]
  wallet              Wallet?
  notifications       Notification[]
  refundRequests      RefundRequest[]
  supportTickets      SupportTicket[]
  emailDeliveries     EmailDelivery[]
}

model EmailOtp {
  id         String     @id @default(uuid())
  userId     String?
  email      String
  purpose    OtpPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose])
}

model Partner {
  id                 String        @id @default(uuid())
  userId             String        @unique
  businessName       String
  taxCode            String        @unique
  representativeName String
  contactEmail       String?
  contactPhone       String?
  address            String?
  bankName           String?
  bankAccountNumber  String?
  status             PartnerStatus @default(PENDING)
  rejectReason       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  members  PartnerMember[]
  branches Branch[]
  vouchers Voucher[]
}

model PartnerMember {
  id        String              @id @default(uuid())
  partnerId String
  userId    String
  branchId  String?
  role      PartnerMemberRole
  status    PartnerMemberStatus @default(INVITED)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id])

  @@unique([partnerId, userId])
  @@index([userId, status])
  @@index([partnerId, role, status])
  @@index([branchId])
}

model Branch {
  id        String   @id @default(uuid())
  partnerId String
  name      String
  address   String
  city      String   @default("Hồ Chí Minh")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  partner         Partner           @relation(fields: [partnerId], references: [id])
  voucherBranches VoucherBranch[]
  usageLogs       VoucherUsageLog[]
  members         PartnerMember[]

  @@unique([partnerId, name])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  vouchers Voucher[]
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  String   @default("HOME_HERO")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position, isActive, sortOrder])
}

model CmsPage {
  id        String        @id @default(uuid())
  slug      String        @unique
  title     String
  content   String
  status    CmsPageStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
}

model Voucher {
  id                String        @id @default(uuid())
  partnerId         String
  categoryId        String
  title             String
  description       String?
  imageUrl          String?
  originalPrice     Decimal       @db.Decimal(12, 0)
  salePrice         Decimal       @db.Decimal(12, 0)
  totalQty          Int
  soldQty           Int           @default(0)
  status            VoucherStatus @default(DRAFT)
  saleStart         DateTime?
  saleEnd           DateTime?
  useStart          DateTime?
  useEnd            DateTime?
  conditions        String?
  cancelPolicy      String?
  allowRefund       Boolean       @default(false)
  refundWindowHours Int           @default(24)
  rejectReason      String?
  approvedAt        DateTime?
  approvedBy        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  partner         Partner         @relation(fields: [partnerId], references: [id])
  category        Category        @relation(fields: [categoryId], references: [id])
  voucherBranches VoucherBranch[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  voucherCodes    VoucherCode[]
  reviews         Review[]

  @@unique([partnerId, title])
  @@index([status])
  @@index([partnerId])
  @@index([categoryId])
}

model VoucherBranch {
  voucherId String
  branchId  String

  voucher Voucher @relation(fields: [voucherId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@id([voucherId, branchId])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  voucherId String
  qty       Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id])
  voucher Voucher @relation(fields: [voucherId], references: [id])

  @@unique([cartId, voucherId])
}

model Order {
  id                 String      @id @default(uuid())
  userId             String
  idempotencyKey     String?
  requestFingerprint String?
  status             OrderStatus @default(PENDING_PAYMENT)
  totalAmount        Decimal     @db.Decimal(12, 0)
  recipientName      String?
  recipientPhone     String?
  note               String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payment       Payment?
  voucherCodes  VoucherCode[]
  refundRequest RefundRequest?
  supportTickets SupportTicket[]

  @@unique([userId, idempotencyKey])
  @@index([status])
  @@index([userId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  voucherId String
  qty       Int
  unitPrice Decimal @db.Decimal(12, 0)

  order   Order   @relation(fields: [orderId], references: [id])
  voucher Voucher @relation(fields: [voucherId], references: [id])

  @@index([orderId])
  @@index([voucherId])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(12, 0)
  providerOrderCode     String?       @unique
  providerPaymentLinkId String?       @unique
  providerReference     String?
  checkoutUrl           String?
  paidAt                DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order   Order           @relation(fields: [orderId], references: [id])
  events  PaymentWebhook[]
}

model PaymentWebhook {
  id        String   @id @default(uuid())
  paymentId String
  eventKey String   @unique
  payload   Json
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id            String                @id @default(uuid())
  walletId      String
  orderId       String?
  type          WalletTransactionType
  amount        Decimal               @db.Decimal(12, 0)
  balanceBefore Decimal               @db.Decimal(12, 0)
  balanceAfter  Decimal               @db.Decimal(12, 0)
  note          String?
  createdAt     DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([orderId])
}

model VoucherCode {
  id        String            @id @default(uuid())
  code      String            @unique
  orderId   String
  voucherId String
  ownerId   String
  status    VoucherCodeStatus @default(ISSUED)
  issuedAt  DateTime          @default(now())
  expiresAt DateTime?
  usedAt    DateTime?

  order     Order             @relation(fields: [orderId], references: [id])
  voucher   Voucher           @relation(fields: [voucherId], references: [id])
  owner     User              @relation(fields: [ownerId], references: [id])
  usageLogs VoucherUsageLog[]

  @@index([code])
  @@index([ownerId])
  @@index([status])
}

model VoucherUsageLog {
  id            String   @id @default(uuid())
  voucherCodeId String
  redeemedBy    String
  branchId      String
  redeemedAt    DateTime @default(now())

  voucherCode VoucherCode @relation(fields: [voucherCodeId], references: [id])
  branch      Branch      @relation(fields: [branchId], references: [id])
}

model RefundRequest {
  id             String       @id @default(uuid())
  orderId        String       @unique
  userId         String
  reason         String
  status         RefundStatus @default(REQUESTED)
  adminNote      String?
  providerRefundReference String?
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model SupportTicket {
  id            String              @id @default(uuid())
  userId        String
  orderId       String?
  type          SupportTicketType
  subject       String
  description   String
  status        SupportTicketStatus @default(OPEN)
  adminResponse String?
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id            String           @id @default(uuid())
  userId        String
  type          NotificationType
  title         String
  message       String
  referenceType String?
  referenceId   String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model EmailDelivery {
  id         String              @id @default(uuid())
  userId     String?
  recipient  String
  subject    String
  template   String
  payload    Json
  status     EmailDeliveryStatus @default(PENDING)
  attempts   Int                 @default(0)
  lastError  String?
  sentAt     DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  voucherId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  voucher Voucher @relation(fields: [voucherId], references: [id])

  @@unique([userId, voucherId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  requestId  String?
  metadata   Json?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([requestId])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
